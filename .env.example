# Скопируй в .env на сервере и подставь свой публичный IP или домен.
# Без этого в presigned URL будет localhost — браузер пытается грузить файлы не на сервер.

# Публичный URL MinIO (S3 API), как его видит браузер (порт 9000).
MINIO_PUBLIC_ENDPOINT=http://YOUR_PUBLIC_IP:9000

# Глобальный CORS для MinIO API (см. MINIO_API_CORS_ALLOW_ORIGIN в docker-compose у сервиса minio).
# Пример строгого списка: MINIO_API_CORS_ALLOW_ORIGIN=https://app.example.com,https://www.example.com
