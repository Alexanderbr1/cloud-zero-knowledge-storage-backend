# Скопируй в .env на сервере и подставь свой публичный IP или домен.
# Без этого в presigned URL будет localhost — браузер пользователя пытается грузить файлы «на свой» ПК, а не на сервер.

# Публичный URL MinIO (S3 API), как его видит браузер (порт 9000).
MINIO_PUBLIC_ENDPOINT=http://YOUR_PUBLIC_IP:9000

# Origin фронта для CORS MinIO (как в адресной строке: схема + хост + порт).
FRONTEND_ORIGIN=http://YOUR_PUBLIC_IP:4200
